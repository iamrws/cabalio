# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=submission-images

# Solana
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_JITO_CABAL_COLLECTION_ADDRESS=your-jito-cabal-collection-address

# Helius (for NFT verification)
HELIUS_API_KEY=your-helius-api-key

# Admin access
ADMIN_WALLET_ADDRESSES=wallet1,wallet2

# Anthropic (for AI scoring)
ANTHROPIC_API_KEY=your-anthropic-api-key

# App URL (must match production domain for CSRF origin validation)
NEXT_PUBLIC_APP_URL=https://cabalio.dev

# NextAuth
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# Optional auth settings
AUTH_SESSION_MAX_AGE_SECONDS=86400

# YouTube Data API v3 (for AI or Not game)
YOUTUBE_API_KEY=your-youtube-api-key

# Rewards payout
REWARDS_CLAIM_ENABLED=false
TREASURY_PRIVATE_KEY=your-base58-encoded-treasury-private-key
TREASURY_KEY_ENCODING=base58
REWARDS_MAX_PAYOUT_LAMPORTS=1000000000
REWARDS_DAILY_LIMIT_LAMPORTS=10000000000
